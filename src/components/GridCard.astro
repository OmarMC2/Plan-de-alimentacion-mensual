---
---
<div class="grid-card">
  <slot name="title" />
  <p>
    <slot name="content" />
  </p>
</div>

<style>
  .grid-card {
    border: 1px solid #e1e8ed;
    border-radius: 8px;
    padding: 15px;
    background: #fff;
  }
  .grid-card p {
    margin-bottom: 0;
  }
  .grid-card :global(.badge) {
    background: #ebf5fb;
    color: #2980b9;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: bold;
    display: inline-block;
    margin-bottom: 0.5rem;
  }
  .grid-card :global(strong) {
    display: block;
    margin-bottom: 0.5rem;
  }
</style>
