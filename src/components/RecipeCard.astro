---
export interface Recipe {
  name: string;
  portions: string[];
  notes: string;
}
export interface Props {
  recipe: Recipe
}
const { recipe } = Astro.props;
---
<div class="recipe-card">
  <h3>{recipe.name}</h3>
  <div class="portions">
    {recipe.portions.map(portion => <p set:html={portion}></p>)}
  </div>
  <p class="libres">{recipe.notes}</p>
</div>

<style>
  .recipe-card {
    background: #fff3e0;
    border-radius: 8px;
    padding: 15px;
    margin-bottom: 15px;
  }
  .recipe-card:last-child {
    margin-bottom: 0;
  }
  h3 {
    margin-top: 0;
    color: var(--accent);
  }
  .portions {
    background: #f1f8e9;
    border-left: 4px solid var(--secondary);
    padding: 8px;
    margin: 10px 0;
    font-size: 0.9rem;
  }
  .libres {
    color: #566573;
    font-size: 0.85rem;
    font-style: italic;
    margin-bottom: 0;
  }
</style>
