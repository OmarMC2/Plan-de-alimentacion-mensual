---
export interface Props {
  title: string;
  id?: string;
}
const { title, id } = Astro.props
---
<section class="container" {id}>
  <h2>{title}</h2>
  <div class="card">
    <slot />
  </div>
</section>

<style>
  .container {
    max-width: 1100px;
    margin: 20px auto;
    padding: 0 15px;
  }
  .card {
    background: white;
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 25px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }
  h2 {
    color: var(--secondary);
    border-bottom: 2px solid var(--secondary);
    padding-bottom: 10px;
    margin-top: 0;
    margin-left: 15px;
    margin-right: 15px;
  }
</style>
